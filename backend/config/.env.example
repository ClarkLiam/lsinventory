# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_secure_secret
FRONTEND_URL=http://localhost:8080

# MySQL
# Ensure your database uses utf8mb4 / utf8mb4_unicode_ci.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ls_inventory
DB_USER=lsinventory
DB_PASSWORD=replace_with_mysql_password

# Optional MySQL pool tuning
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
